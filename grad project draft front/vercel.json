{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!password-reset\\.html|assets/.*|.*\\.js|.*\\.css).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/password-reset.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
